# ===== OpenWA AI Bot configuration =====

# This bot's HTTP port (OpenWA posts the webhook here). Keep 3000 inside compose.
PORT=3000

# OpenWA gateway REST API.
# Inside docker compose use the service name; from the host use http://localhost:2785/api
OPENWA_BASE_URL=http://openwa:2785/api
# Leave empty in dev (API_MASTER_KEY is unset). Set it if you enable API auth.
OPENWA_API_KEY=

# The WhatsApp session id created in OpenWA (e.g. sess_abc123).
SESSION_ID=

# Shared secret used to register + verify the webhook HMAC. Use any long random string.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Comma-separated WhatsApp chat ids the bot is allowed to answer (reactive mode).
# Group ids end in @g.us, direct chats end in @c.us.
ALLOWED_CHATS=
# false = bot only replies in groups from ALLOWED_CHATS, never to 1:1 DMs.
REPLY_TO_DIRECT=false

# ===== LLM providers (fallback chain) =====
# Tried in order; first with a valid API key wins.
LLM_PROVIDERS=gemini,openrouter,huggingface

# Google Gemini (primary)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_SEARCH_MODEL=gemini-2.5-flash

# OpenRouter (fallback 1) — free key at openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# HuggingFace (fallback 2) — free key at huggingface.co/settings/tokens
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ===== Knowledge base (Obsidian vault) =====
VAULT_DIR=/vault
RAG_TOP_K=6
RAG_MAX_CHARS=120000

# ===== Scheduled broadcaster =====
# TEST_MODE=true  → all jobs fire every 5 min to TEST_GROUP_ID (for QA)
# TEST_MODE=false → jobs fire within their time blocks to PRODUCTION_GROUPS
TEST_MODE=false
TEST_GROUP_ID=

# Comma-separated production group ids (used when TEST_MODE=false).
PRODUCTION_GROUPS=

# Timezone for all scheduled jobs (IANA format).
SCHEDULER_TZ=America/New_York

# Job: NASDAQ fundamental analysis (every Mon/Wed/Fri by default)
# Time block: fires at BLOCK start, then waits a random offset within the window.
NASDAQ_ANALYSIS_BLOCK=08:00-09:30
NASDAQ_ANALYSIS_DAYS=1,3,5

# Job: trading tips & best practices (Tue/Thu by default)
TRADING_TIPS_BLOCK=09:30-10:30
TRADING_TIPS_DAYS=2,4

# Job: news / notable quote from a public figure (Mon–Fri by default)
NEWS_SHARE_BLOCK=15:00-16:30
NEWS_SHARE_DAYS=1-5

# ===== Telegram signals listener =====
# When a signal arrives in SIGNALS_THREAD_ID, nasdaq-analysis fires with the signal as context.
# The bot token must be admin in the channel. Leave SIGNALS_BOT_TOKEN empty to disable.
SIGNALS_BOT_TOKEN=
SIGNALS_CHANNEL_ID=
SIGNALS_THREAD_ID=

# ===== Guardrails =====
IGNORE_FROM_ME=true
MAX_INBOUND_CHARS=4000

# Token to protect POST /admin/nasdaq-report (header x-admin-token). Empty = open in dev.
ADMIN_TOKEN=
