# ===== OpenWA AI Bot configuration =====

# This bot's HTTP port (OpenWA posts the webhook here). Keep 3000 inside compose.
PORT=3000

# OpenWA gateway REST API.
# Inside docker compose use the service name; from the host use http://localhost:2785/api
OPENWA_BASE_URL=http://openwa:2785/api
# Leave empty in dev (API_MASTER_KEY is unset). Set it if you enable API auth.
OPENWA_API_KEY=

# The WhatsApp session id created in OpenWA (e.g. sess_abc123).
SESSION_ID=

# Shared secret used to register + verify the webhook HMAC. Use any long random string.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Comma-separated WhatsApp chat ids the bot is allowed to answer.
# Group ids end in @g.us, direct chats end in @c.us. Get group ids from
# GET /api/sessions/:id/groups. Example:
# ALLOWED_CHATS=120363000000000000@g.us,120363111111111111@g.us
ALLOWED_CHATS=
# Set true to also answer 1:1 direct messages (default false = groups only).
REPLY_TO_DIRECT=false

# ===== Model / provider (default: Claude via the Agent SDK) =====
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TURNS=8
# Optional: restrict which MCP tools the agent may call (comma list of mcp__server__tool).
# Leave empty to allow all tools the Obsidian MCP server exposes.
AGENT_ALLOWED_TOOLS=

# ===== Guardrails =====
IGNORE_FROM_ME=true
MAX_INBOUND_CHARS=4000
